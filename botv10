        'TRENDING': {'rsi_long': 42, 'rsi_short': 58, 'vol_mult': 1.4, 'sl_mult': 2.2, 'min_ulduz': MIN_ULDUZ},
        'RANGING':  {'rsi_long': 38, 'rsi_short': 62, 'vol_mult': 1.5, 'sl_mult': 2.0, 'min_ulduz': MIN_ULDUZ + 0.3},
        'HIGH_VOL': {'rsi_long': 35, 'rsi_short': 65, 'vol_mult': 1.7, 'sl_mult': 3.0, 'min_ulduz': MIN_ULDUZ + 1.0},
        'CRISIS':   {'rsi_long': 30, 'rsi_short': 70, 'vol_mult': 2.0, 'sl_mult': 3.5, 'min_ulduz': 99},
    }
    p        = params.get(rejim, params['RANGING']).copy()
    asset_key = asset_type.upper()
    if asset_key in ASSET_PARAMS:
        ap = ASSET_PARAMS[asset_key]
        p['rsi_long']  = ap.get('rsi_long',  p['rsi_long'])
        p['rsi_short'] = ap.get('rsi_short', p['rsi_short'])
        p['vol_mult']  = ap.get('vol_mult',  p['vol_mult'])
        p['rr_min']    = ap.get('rr_min',    RR_MINIMUM)
        if asset_key == 'FOREX':
            p['vol_mult'] = max(p['vol_mult'] - 0.1, 1.1)
        elif asset_key in ('STOCK','INDEX'):
            p['rsi_long']  = max(30, p['rsi_long']  - 2)
            p['rsi_short'] = min(70, p['rsi_short'] + 2)
    else:
        p['rr_min'] = RR_MINIMUM
    return p

