#  WYCKOFF
# ══════════════════════════════════════════
def wyckoff_fazi_tap(df):
    try:
        vol_col        = 'vol' if 'vol' in df.columns else 'Volume'
        price_change   = (df['Close'].iloc[-2] - df['Close'].iloc[-22]) / df['Close'].iloc[-22]
        avg_vol        = df[vol_col].iloc[-20:].mean()
        curr_vol       = df[vol_col].iloc[-2]
        vol_artim      = curr_vol / avg_vol if avg_vol else 1
        rsi_val        = ta.rsi(df['Close'], length=14).iloc[-2]

        if price_change < -0.05 and rsi_val < 45 and vol_artim > 1.3:  return 'ACCUMULATION'
        elif price_change > 0.05 and rsi_val > 55 and vol_artim > 1.3: return 'DISTRIBUTION'
        elif price_change > 0.03 and rsi_val > 50:                      return 'MARKUP'
        elif price_change < -0.03 and rsi_val < 50:                     return 'MARKDOWN'
        return 'NEYTRAL'
    except:
        return 'NEYTRAL'

