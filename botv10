WFO_LOG  = "wfo_log.csv"
wfo_lock = threading.Lock()

def wfo_simulate(frames, asset_type, symbol, min_ulduz_val, rsi_long_of, rsi_short_of, vol_mult_of):
    global MIN_ULDUZ
    with wfo_lock:
        orig_min    = MIN_ULDUZ
        orig_params = {k: v.copy() for k, v in ASSET_PARAMS.items()}
        MIN_ULDUZ   = min_ulduz_val
        for k in ASSET_PARAMS:
            ASSET_PARAMS[k]['rsi_long']  = orig_params[k]['rsi_long']  + rsi_long_of
            ASSET_PARAMS[k]['rsi_short'] = orig_params[k]['rsi_short'] + rsi_short_of
            ASSET_PARAMS[k]['vol_mult']  = max(1.0, orig_params[k]['vol_mult'] + vol_mult_of)
        try:
            neticeler  = backtest_single(frames, asset_type=asset_type, symbol=symbol, silent=True)
            qapalanmis = [n for n in neticeler if n['hit'] in ('TP','SL')]
            if not qapalanmis: return 0.0, 0
            tp_say   = sum(1 for n in qapalanmis if n['hit'] == 'TP')
            win_rate = tp_say / len(qapalanmis) * 100
            return win_rate, len(qapalanmis)
        finally:
            MIN_ULDUZ = orig_min
            for k in ASSET_PARAMS:
                ASSET_PARAMS[k] = orig_params[k]

def walk_forward_optimizasiya(symbol='BTC/USDT', asset_type='crypto'):
    print(f"\n[WFO] {symbol} üçün Walk-Forward Optimizasiya başlayır...")
    try:
