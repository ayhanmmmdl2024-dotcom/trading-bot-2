            cut = bolme // 4
            frames_in[tf]  = df_r.iloc[:cut]
            frames_out[tf] = df_r.iloc[cut:]
        elif tf == '1d':
            cut = bolme // 24
            frames_in[tf]  = df_r.iloc[:cut]
            frames_out[tf] = df_r.iloc[cut:]
        else:
            frames_in[tf]  = df_r
            frames_out[tf] = df_r

    # ✅ BUG7: param_adlar və param_degerler artıq qlobal olaraq təyin edilib
    en_yaxsi_wr     = -1
    en_yaxsi_params = {}
    toplam          = 1
    for v in param_degerler:
        toplam *= len(v)
    print(f"[WFO] {toplam} kombinasiya test ediləcək...")

    for i, kombo in enumerate(itertools.product(*param_degerler), 1):
        p  = dict(zip(param_adlar, kombo))
        wr, n = wfo_simulate(frames_in, asset_type, symbol, p['min_ulduz'],
                              p['rsi_long_ofset'], p['rsi_short_ofset'], p['vol_mult_ofset'])
        if i % 20 == 0:
            print(f"[WFO] {i}/{toplam}...")
        if wr > en_yaxsi_wr and n >= 5:
            en_yaxsi_wr     = wr
            en_yaxsi_params = p.copy()

    if not en_yaxsi_params:
        print("[WFO] Uyğun parametr tapılmadı.")
        return

    wr_out, n_out = wfo_simulate(frames_out, asset_type, symbol,
                                  en_yaxsi_params['min_ulduz'],
                                  en_yaxsi_params['rsi_long_ofset'],
                                  en_yaxsi_params['rsi_short_ofset'],
                                  en_yaxsi_params['vol_mult_ofset'])

    overfit     = abs(en_yaxsi_wr - wr_out) > 15
    overfit_str = "⚠️ OVERFİT RİSKİ" if overfit else "✅ Stabil"

    telegram_gonder(
        f"⚙️ <b>WALK-FORWARD OPTİMİZASİYA</b>\n\n"
        f"💎 Aktiv: #{symbol.replace('/USDT','')}\n"
        f"📥 In-sample WR:  {en_yaxsi_wr:.1f}%\n"
        f"📤 Out-sample WR: {wr_out:.1f}% ({n_out} siqnal)\n"
        f"🔧 Min ulduz: {en_yaxsi_params.get('min_ulduz')}\n"
        f"📊 Qiymətləndirmə: {overfit_str}"
    )
    return en_yaxsi_params, en_yaxsi_wr, wr_out

