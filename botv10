def backtest_single(frames_tam, asset_type='crypto', symbol='', silent=False):
    df1h_tam = frames_tam.get('1h')
    if df1h_tam is None or len(df1h_tam) < 300:
        return []

    neticeler = []
    df1h_r    = df1h_tam.reset_index(drop=True)

    for i in range(200, len(df1h_r) - 1):
        frames_kesik = {}
        for tf, df_full in frames_tam.items():
            df_r = df_full.reset_index(drop=True)
            if tf == '1h':   frames_kesik[tf] = df_r.iloc[:i+1]
            elif tf == '4h': frames_kesik[tf] = df_r.iloc[:max(1, i//4)]
            elif tf == '1d': frames_kesik[tf] = df_r.iloc[:max(1, i//24)]
            elif tf == '15m': frames_kesik[tf] = df_r.iloc[:min(len(df_r), i*4)]
            else:            frames_kesik[tf] = df_r

        res = analiz_et(frames_kesik, asset_type=asset_type, symbol=symbol)
        if res is None:
            continue

        entry, tp, sl, yon = res['entry'], res['tp'], res['sl'], res['yon']
        gelecek = df1h_r.iloc[i+1:i+49]
        hit     = None
        for _, bar in gelecek.iterrows():
            if yon == 'LONG':
                if bar['Low']  <= sl: hit = 'SL'; break
                if bar['High'] >= tp: hit = 'TP'; break
            else:
                if bar['High'] >= sl: hit = 'SL'; break
                if bar['Low']  <= tp: hit = 'TP'; break
        if hit is None:
            hit = 'AÇIQ'

        neticeler.append({
            'symbol': symbol, 'bar_idx': i, 'yon': yon,
            'entry': round(entry,6), 'tp': round(tp,6), 'sl': round(sl,6),
            'rr': res['rr'], 'skor': res['skor'], 'rejim': res['rejim'], 'hit': hit,
        })
    return neticeler

