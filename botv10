def xeberleri_yoxla():
    try:
        today = datetime.now().strftime('%Y-%m-%d')
        url   = f"https://finnhub.io/api/v1/calendar/economic?from={today}&to={today}&token={FINNHUB_API_KEY}"
        resp  = requests.get(url, timeout=10).json()
        now_t = datetime.now()
        for event in resp.get('economicCalendar', []):
            impact = event.get('impact', '').lower()
            if impact == 'high':
                window_minutes = 90
            elif impact == 'medium':
                window_minutes = 45
            else:
                continue
            t_str = event.get('time')
            if t_str:
                try:
                    ev_t = datetime.strptime(t_str, '%Y-%m-%d %H:%M:%S')
                    if now_t - timedelta(minutes=window_minutes) < ev_t < now_t + timedelta(minutes=window_minutes):
                        return True, event.get('event','Mühüm Xəbər'), impact
                except:
                    pass
        return False, None, None
    except Exception as e:
        print(f"Xəbər yoxlama xətası: {e}")
        return False, None, None

