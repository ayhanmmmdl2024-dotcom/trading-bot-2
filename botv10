# ══════════════════════════════════════════
#  TOP-DOWN MTF ANALİZİ
# ══════════════════════════════════════════
def mtf_trend_yoxla(frames):
    yon_lar   = []
    tf_sirasi = ['1d', '4h', '1h', '15m']
    for tf in tf_sirasi:
        df = frames.get(tf)
        if df is None or len(df) < 50:
            continue
        try:
            c      = df['Close'].iloc[-2]
            ema50  = ta.ema(df['Close'], length=50).iloc[-2]
            ema200 = ta.ema(df['Close'], length=200).iloc[-2] if len(df) >= 200 else ema50
            if c > ema50 > ema200:   yon_lar.append('LONG')
            elif c < ema50 < ema200: yon_lar.append('SHORT')
            else:                    yon_lar.append('NEYTRAL')
        except:
            yon_lar.append('NEYTRAL')

    if not yon_lar:
        return 'NEYTRAL', 0

    long_say  = yon_lar.count('LONG')
    short_say = yon_lar.count('SHORT')

    if long_say >= 1:   return 'LONG',  long_say
    elif short_say >= 1: return 'SHORT', short_say
    return 'NEYTRAL', 0

# ══════════════════════════════════════════
#  ORDER BLOCK
# ══════════════════════════════════════════
def order_block_tap(df, yon):
    try:
        window = df.iloc[-51:-1].copy()
        if len(window) < 10:
            return False, 0, 0
        price = df['Close'].iloc[-2]
        for i in range(len(window)-2, 5, -1):
            curr      = window.iloc[i]
            prev      = window.iloc[i-1]
            body_curr = abs(curr['Close'] - curr['Open'])
            body_prev = abs(prev['Close'] - prev['Open'])
            if yon == 'LONG':
                if curr['Close'] > curr['Open'] and body_curr > body_prev * 1.5 and prev['Close'] < prev['Open']:
                    if prev['Low'] <= price <= prev['High']:
                        return True, prev['Low'], prev['High']
            elif yon == 'SHORT':
                if curr['Close'] < curr['Open'] and body_curr > body_prev * 1.5 and prev['Close'] > prev['Open']:
                    if prev['Low'] <= price <= prev['High']:
                        return True, prev['Low'], prev['High']
        return False, 0, 0
    except:
        return False, 0, 0

# ══════════════════════════════════════════
#  FAIR VALUE GAP
# ══════════════════════════════════════════
def fvg_tap(df, yon):
    try:
        price  = df['Close'].iloc[-2]
        window = df.iloc[-30:-1]
        for i in range(len(window)-1, 1, -1):
            s0 = window.iloc[i-2]
            s2 = window.iloc[i]
            if yon == 'LONG':
                fvg_low, fvg_high = s0['High'], s2['Low']
                if fvg_high > fvg_low and fvg_low <= price <= fvg_high:
                    return True, fvg_low, fvg_high
            elif yon == 'SHORT':
                fvg_high, fvg_low = s0['Low'], s2['High']
                if fvg_low < fvg_high and fvg_low <= price <= fvg_high:
                    return True, fvg_low, fvg_high
        return False, 0, 0
    except:
        return False, 0, 0

# ══════════════════════════════════════════
#  RSI DİVERGENCE
# ══════════════════════════════════════════
def rsi_divergence_yoxla(df, yon):
    try:
        rsi          = ta.rsi(df['Close'], length=14)
        window_price = df['Close'].iloc[-20:-1]
        window_rsi   = rsi.iloc[-20:-1]
        rsi_now      = rsi.iloc[-2]
        price_now    = df['Close'].iloc[-2]

        if yon == 'LONG':
            idx = window_price.idxmin()
            if price_now <= window_price.min() * 1.005 and rsi_now > window_rsi.loc[idx] + 3:
                return True
        elif yon == 'SHORT':
            idx = window_price.idxmax()
            if price_now >= window_price.max() * 0.995 and rsi_now < window_rsi.loc[idx] - 3:
                return True
        return False
    except:
        return False

# ══════════════════════════════════════════
#  PIN BAR
# ══════════════════════════════════════════
def pin_bar_yoxla(df, yon):
    try:
        s    = df.iloc[-2]
        body = abs(s['Close'] - s['Open'])
        if body == 0:
            return False
        lower_wick = min(s['Open'], s['Close']) - s['Low']
        upper_wick = s['High'] - max(s['Open'], s['Close'])
        if yon == 'LONG'  and lower_wick >= body * 2: return True
        if yon == 'SHORT' and upper_wick >= body * 2: return True
        return False
    except:
        return False

