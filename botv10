def breakout_yoxla(df, yon):
    try:
        price    = df['Close'].iloc[-2]
        high_20  = df['High'].iloc[-22:-2].max()
        low_20   = df['Low'].iloc[-22:-2].min()
        vol_col  = 'vol' if 'vol' in df.columns else 'Volume'
        avg_vol  = df[vol_col].rolling(20).mean().iloc[-2]
        curr_vol = df[vol_col].iloc[-2]
        vol_ok   = curr_vol > avg_vol * 1.2

        if yon == 'LONG'  and price > high_20 and vol_ok: return True
        if yon == 'SHORT' and price < low_20  and vol_ok: return True
        return False
    except:
        return False

# ══════════════════════════════════════════
#  DELİSTED FİLTER
# ══════════════════════════════════════════
def delisted_filter(pairs, markets, tickers):
    temiz   = []
    silindi = 0
    for sym in pairs:
        try:
            market    = markets.get(sym, {})
            ticker    = tickers.get(sym, {})
            quote_vol = ticker.get('quoteVolume') or 0
            last      = ticker.get('last') or 0
            bid       = ticker.get('bid') or 0
            ask       = ticker.get('ask') or 0
            if not market.get('active', True) or quote_vol <= 0 or last <= 0 or bid <= 0 or ask <= 0:
                silindi += 1
                continue
            temiz.append(sym)
        except:
            silindi += 1
    print(f"[DELİSTED] {silindi} aktiv silindi → {len(temiz)} sağlam aktiv qaldı.")
    return temiz

# ══════════════════════════════════════════
#  ƏSAS ANALİZ
# ══════════════════════════════════════════
def analiz_et(frames, asset_type='crypto', symbol=''):
    df1h = frames.get('1h')
    if df1h is None or len(df1h) < 150:
        return None

    try:
        price   = df1h['Close'].iloc[-2]
        high_1h = df1h['High'].iloc[-2]
        low_1h  = df1h['Low'].iloc[-2]
        vol_col = 'vol' if 'vol' in df1h.columns else 'Volume'

        rsi1h  = ta.rsi(df1h['Close'], length=14).iloc[-2]
        atr1h  = ta.atr(df1h['High'], df1h['Low'], df1h['Close'], length=14).iloc[-2]
        ema50  = ta.ema(df1h['Close'], length=50).iloc[-2]
        ema200 = ta.ema(df1h['Close'], length=200).iloc[-2] if len(df1h) >= 200 else ema50

        avg_vol  = df1h[vol_col].rolling(20).mean().iloc[-2]
        curr_vol = df1h[vol_col].iloc[-2]

        high_20 = df1h['High'].iloc[-21:-2].max()
        low_20  = df1h['Low'].iloc[-21:-2].min()

        rejim, atr_ratio, adx_val = rejim_tespit(df1h)
        if rejim == 'CRISIS':
            return None

        # ✅ BUG2: dinamik_params yalnız bir dəfə çağırılır
        p = dinamik_params(rejim, asset_type)

        mtf_yon, mtf_skor = mtf_trend_yoxla(frames)

        # ✅ BUG3: NEYTRAL halda return None
        if mtf_yon == 'NEYTRAL':
            return None

        yon = mtf_yon

        if yon == 'LONG':
            sweep  = (low_1h < low_20) and (price > low_20)
            ema_ok = price > ema200 and ema50 > ema200
            rsi_ok = rsi1h <= p['rsi_long']
        else:
            sweep  = (high_1h > high_20) and (price < high_20)
            ema_ok = price < ema200 and ema50 < ema200
            rsi_ok = rsi1h >= p['rsi_short']

        vol_ok = curr_vol > avg_vol * p['vol_mult']

        pullback_mode = False
        if not sweep:
            df4h = frames.get('4h')
            if df4h is not None and len(df4h) >= 50:
                try:
                    ema50_4h = ta.ema(df4h['Close'], length=50).iloc[-2]
                    if yon == 'LONG'  and abs(price - ema50_4h) / ema50_4h < 0.025 and price > ema50_4h * 0.975:
                        pullback_mode = True
                    elif yon == 'SHORT' and abs(price - ema50_4h) / ema50_4h < 0.025 and price < ema50_4h * 1.025:
                        pullback_mode = True
                except:
                    pass

        # ✅ BUG1: breakout dəyişəni mövcuddur
        breakout = breakout_yoxla(df1h, yon)

        if not sweep and not pullback_mode and not breakout:
            return None
        if not ema_ok or not rsi_ok or not vol_ok:
            return None

        # ✅ BUG8: RR_MINIMUM standart istifadə edilir
        rr_min  = p.get('rr_min', RR_MINIMUM)
        sl_mult = p['sl_mult']

        if yon == 'LONG':
            sl = (df1h['Low'].iloc[-2] - atr1h * sl_mult) if sweep else (price - atr1h * sl_mult)
            tp = price + (price - sl) * rr_min
        else:
            sl = (df1h['High'].iloc[-2] + atr1h * sl_mult) if sweep else (price + atr1h * sl_mult)
            tp = price - (sl - price) * rr_min

        risk   = abs(price - sl)
        reward = abs(price - tp)
        if risk == 0 or reward / risk < rr_min:
            return None

        # ══ SCORING ══
        skor = 0.0
        skor += min(mtf_skor, 4) * 0.5
        if ema_ok:                                    skor += 1.0
        if sweep:                                     skor += 1.0
        elif pullback_mode:                           skor += 0.7
        elif breakout:                                skor += 0.8
        if yon == 'LONG'  and rsi1h < 35:            skor += 1.5
        elif yon == 'LONG'  and rsi1h < 42:          skor += 0.8
        elif yon == 'SHORT' and rsi1h > 65:          skor += 1.5
        elif yon == 'SHORT' and rsi1h > 58:          skor += 0.8

        ob_var, ob_low, ob_high   = order_block_tap(df1h, yon)
        fvg_var, fvg_low, fvg_hi = fvg_tap(df1h, yon)

        if ob_var:                                    skor += 1.0
        if fvg_var:                                   skor += 1.0
        if rsi_divergence_yoxla(df1h, yon):          skor += 1.0
        if pin_bar_yoxla(df1h, yon):                 skor += 0.5

        wyckoff = wyckoff_fazi_tap(df1h)
        if yon == 'LONG'  and wyckoff == 'ACCUMULATION': skor += 1.0
        elif yon == 'SHORT' and wyckoff == 'DISTRIBUTION': skor += 1.0

        vol_ratio = curr_vol / avg_vol if avg_vol else 1
        if vol_ratio > 2.0:   skor += 1.0
        elif vol_ratio > 1.5: skor += 0.5

        df15m = frames.get('15m')
        if df15m is not None and len(df15m) >= 30:
            try:
                rsi15 = ta.rsi(df15m['Close'], length=14).iloc[-2]
                if yon == 'LONG'  and rsi15 < 50: skor += 0.5
                elif yon == 'SHORT' and rsi15 > 50: skor += 0.5
            except:
                pass

        if skor < p['min_ulduz']:
            return None

        return {
            'type':      f"{'LONG 📈' if yon == 'LONG' else 'SHORT 📉'}",
            'yon':       yon,
            'entry':     round(price, 6),
            'tp':        round(tp, 6),
            'sl':        round(sl, 6),
            'rsi':       round(rsi1h, 1),
            'ema200':    round(ema200, 6),
            'skor':      round(skor, 1),
            'rejim':     rejim,
            'atr_ratio': round(atr_ratio, 2),
            'adx':       round(adx_val, 1),
            'rr':        round(reward / risk, 2),
            'ob':        ob_var,
            'fvg':       fvg_var,
            'wyckoff':   wyckoff,
            'mtf_skor':  mtf_skor,
            'vol_ratio': round(vol_ratio, 2),
            'pullback':  pullback_mode,
            'breakout':  breakout,
        }
    except:
        return None

