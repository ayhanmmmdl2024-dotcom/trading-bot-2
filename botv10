#  BAZAR REJİMİ
# ══════════════════════════════════════════
def rejim_tespit(df):
    try:
        atr     = ta.atr(df['High'], df['Low'], df['Close'], length=14)
        atr_val = atr.iloc[-1]
        atr_mean = atr.rolling(50).mean().iloc[-1]
        atr_ratio = atr_val / atr_mean if atr_mean else 1.0

        adx_df  = ta.adx(df['High'], df['Low'], df['Close'], length=14)
        adx_col = [c for c in adx_df.columns if c.startswith('ADX')]
        adx_val = adx_df[adx_col[0]].iloc[-1] if adx_col else 20

        if atr_ratio > 3.0:    return 'CRISIS',   atr_ratio, adx_val
        elif atr_ratio > 1.8:  return 'HIGH_VOL', atr_ratio, adx_val
        elif adx_val > 25:     return 'TRENDING', atr_ratio, adx_val
        else:                  return 'RANGING',  atr_ratio, adx_val
    except:
        return 'RANGING', 1.0, 20

