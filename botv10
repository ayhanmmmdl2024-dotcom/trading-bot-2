def sentiment_al(symbol):
    try:
        clean     = symbol.replace('/USDT','').replace('=X','').replace('=F','').replace('^','').replace('-','').split('.')[0]
        today     = datetime.now().strftime('%Y-%m-%d')
        yesterday = (datetime.now() - timedelta(days=1)).strftime('%Y-%m-%d')
        url       = f"https://finnhub.io/api/v1/company-news?symbol={clean}&from={yesterday}&to={today}&token={FINNHUB_API_KEY}"
        news      = requests.get(url, timeout=8).json()
        if not isinstance(news, list) or len(news) == 0:
            return 0, "NEYTRAL"
        pozitiv = ['surge','rally','gain','rise','bull','up','growth','record','beat','strong']
        neqativ = ['drop','fall','crash','loss','bear','down','decline','miss','weak','cut']
        skor    = 0
        for item in news[:10]:
            headline = item.get('headline','').lower()
            skor    += sum(1 for w in pozitiv if w in headline)
            skor    -= sum(1 for w in neqativ if w in headline)
        if skor > 2:   return skor, "BULLISH"
        elif skor < -2: return skor, "BEARISH"
        return skor, "NEYTRAL"
    except:
        return 0, "NEYTRAL"

